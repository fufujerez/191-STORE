local Player = game.Players.LocalPlayer
local CoreGui = game:GetService("CoreGui")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Bersihkan UI lama
if CoreGui:FindFirstChild("OneNineOneStore") then CoreGui.OneNineOneStore:Destroy() end

local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "OneNineOneStore"
ScreenGui.ResetOnSpawn = false

-- 1. Main Frame
local MainFrame = Instance.new("ImageLabel", ScreenGui)
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 180, 0, 270)
MainFrame.Position = UDim2.new(0.5, -90, 0.5, -135)
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainFrame.Image = "rbxassetid://YOUR_IMAGE_ID_HERE" -- Ganti dengan ID Decal kamu
MainFrame.ScaleType = Enum.ScaleType.Crop
MainFrame.Active = true
MainFrame.Draggable = true

-- 2. Judul "191 STORE"
local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1, 0, 0, 45)
Title.Text = "191 STORE"
Title.Font = Enum.Font.GothamBold
Title.TextColor3 = Color3.new(1, 1, 1)
Title.TextSize = 18
Title.BackgroundTransparency = 1

-- 3. Toggle Menu (Z)
UIS.InputBegan:Connect(function(input, chat)
    if chat then return end
    if input.KeyCode == Enum.KeyCode.Z then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

-- 4. Fitur ESP
local espEnabled = false
local function toggleESP()
    espEnabled = not espEnabled
    if not espEnabled then
        for _, p in pairs(game.Players:GetPlayers()) do
            local old = CoreGui:FindFirstChild("ESP_" .. p.Name)
            if old then old:Destroy() end
        end
    end
end

RunService.RenderStepped:Connect(function()
    if espEnabled then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local box = CoreGui:FindFirstChild("ESP_" .. p.Name) or Instance.new("BoxHandleAdornment", CoreGui)
                box.Name = "ESP_" .. p.Name
                box.Size = Vector3.new(4, 6, 0.5)
                box.AlwaysOnTop = true
                box.Transparency = 0.6
                box.Color3 = Color3.new(1, 0, 0)
                box.Adornee = p.Character.HumanoidRootPart
            end
        end
    end
end)

-- 5. Tombol Creator
local function createBtn(text, func)
    local b = Instance.new("TextButton", MainFrame)
    b.Size = UDim2.new(0.85, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    b.Text = text
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamSemibold
    b.TextSize = 10
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
    b.MouseButton1Click:Connect(func)
end

local Layout = Instance.new("UIListLayout", MainFrame)
Layout.Padding = UDim.new(0, 6)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
Layout.SortOrder = Enum.SortOrder.LayoutOrder
Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 45)

-- 6. Daftar Tombol
createBtn("SET WAYPOINT", function()
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if root then _G.wp = root.Position end
end)

createBtn("TELEPORT", function()
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if root and _G.wp then root.CFrame = CFrame.new(_G.wp + Vector3.new(0, 2, 0)) end
end)

createBtn("BLINK (Q)", function()
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if root then root.CFrame = root.CFrame * CFrame.new(0, 0, -5) end
end)

createBtn("WALKSPEED (20)", function()
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = 20
    end
end)

createBtn("TOGGLE ESP", toggleESP)

createBtn("CLOSE (Z)", function() MainFrame.Visible = false end)

-- Keybind Q tetap aktif untuk Blink
UIS.InputBegan:Connect(function(input, chat)
    if not chat and input.KeyCode == Enum.KeyCode.Q then
        local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = root.CFrame * CFrame.new(0, 0, -5) end
    end
end)
